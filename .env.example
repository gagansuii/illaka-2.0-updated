# Database connection (Prisma will also use SHADOW_DATABASE_URL for migrations)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ilaka_events?schema=public&sslmode=require"
SHADOW_DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ilaka_shadow?schema=public&sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="some-long-random-string"

# Redis (optional; used for rate limiting if provided)
REDIS_URL="redis://localhost:6379"

# OpenAI / Pinecone (optional features)
OPENAI_API_KEY=""
PINECONE_API_KEY=""
PINECONE_INDEX="ilaka-events"

# Razorpay (payments)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Optional IP geolocation fallback
IPINFO_TOKEN=""

# Pricing defaults (paise)
NEXT_PUBLIC_SUBSCRIPTION_PRICE="49900"
NEXT_PUBLIC_HOSTING_FEE_THRESHOLD="50"
NEXT_PUBLIC_HOSTING_FEE_AMOUNT="25000"
NEXT_PUBLIC_PROMOTION_PRICE="15000"
